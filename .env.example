# tend — Supabase config
# Copy this file to .env.local and fill in the two values from your project at
# https://supabase.com  ->  Project Settings -> API.
# Vite only exposes vars prefixed with VITE_ to the browser. The anon key is
# safe to ship to the client; row-level security is what protects the data.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-anon-public-key
